LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
GOOGLE_API_KEY=
QUERY_REWRITE_PROVIDER=gemini
QUERY_REWRITE_MODEL=qwen2.5:3b-instruct

DENSE_MODEL=BAAI/bge-m3
SPARSE_MODEL=Qdrant/bm25
SEARCH_SCORE_THRESHOLD=0.3
CHILD_COLLECTION=document_child_chunks_bge_m3
DIRECT_SINGLE_QUESTION=true
DIRECT_RETRIEVAL_LIMIT=5
DIRECT_RETRIEVAL_RETRIES=2
MAX_TOOL_CALLS=5
MAX_ITERATIONS=4

# Optional local fallback.
# LLM_PROVIDER=ollama
# LLM_MODEL=qwen2.5:3b-instruct
# OLLAMA_BASE_URL=http://localhost:11434

# For local development, this can move query rewriting off Gemini while keeping
# final answers on Gemini:
# QUERY_REWRITE_PROVIDER=ollama

# Optional OCR fallback for scanned PDFs. Requires local Tesseract data.
# ENABLE_PDF_OCR=false
# PDF_OCR_LANGUAGE=chi_sim+eng
